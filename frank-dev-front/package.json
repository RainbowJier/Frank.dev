{
  "name": "frank-dev-front",
  "version": "3.9.0",
  "description": "Frank.dev",
  "author": "Frank",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:prod": "vite build",
    "build:stage": "vite build --mode staging",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx --fix",
    "format": "prettier --write .",
    "prepare": "husky",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "lint-staged": {
    "*.{js,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css}": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@element-plus/icons-vue": "2.3.1",
    "@vueuse/core": "10.11.0",
    "apifox-mcp-server": "^0.0.17",
    "axios": "^1.13.2",
    "clipboard": "2.0.11",
    "element-plus": "^2.11.8",
    "fuse.js": "6.6.2",
    "js-beautify": "1.14.11",
    "js-cookie": "3.0.5",
    "nprogress": "0.2.0",
    "pinia": "2.1.7",
    "vue": "3.4.31",
    "vue-router": "4.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.6.1",
    "@commitlint/config-conventional": "^18.6.3",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/ui": "^1.6.1",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^9.33.0",
    "husky": "^9.1.7",
    "jsdom": "^24.1.3",
    "lint-staged": "^15.5.2",
    "prettier": "^3.7.4",
    "terser": "^5.44.1",
    "unplugin-auto-import": "0.17.6",
    "unplugin-vue-setup-extend-plus": "1.0.1",
    "vite": "^6.0.0",
    "vite-plugin-compression": "0.5.1",
    "vite-plugin-svg-icons": "2.0.1",
    "vitest": "^1.6.1"
  },
  "overrides": {
    "quill": "2.0.2",
    "vite-plugin-svg-icons": {
      "svg-baker": {
        "postcss": "^8.4.31",
        "micromatch": "^4.0.8",
        "braces": "^3.0.3"
      }
    }
  }
}
